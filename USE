<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Van Subaru Finance Tool</title>
  <link rel="stylesheet" href="./style.css">
</head>
<body>
  <div class="app" id="app">
    <header class="header card">
      <div class="brand">
        <img src="./logo.png" alt="Van Subaru logo" class="logo">
        <div>
          <h1>Van Subaru of North Kansas City</h1>
          <p>Real Cost vs Tax-Adjusted Cost</p>
        </div>
      </div>
      <button id="closeModeBtn" class="btn">Close Mode</button>
    </header>

    <section class="card">
      <h2>Base Deal</h2>

      <div class="field">
        <div class="row">
          <label for="interest">Base Interest</label>
          <strong id="interestValue">$4,000</strong>
        </div>
        <input id="interest" type="range" min="0" max="10000" step="500" value="4000">
      </div>

      <div class="field">
        <div class="row">
          <label for="taxRate">Tax Rate</label>
          <strong id="taxRateValue">20%</strong>
        </div>
        <input id="taxRate" type="range" min="10" max="40" step="1" value="20">
      </div>

      <div class="field">
        <div class="row">
          <label>Loan Term</label>
          <strong id="termValue">60 months</strong>
        </div>
        <div class="term-buttons" id="termButtons"></div>
      </div>
    </section>

    <section class="card">
      <h2>Add Protection Products</h2>

      <div class="field">
        <div class="row">
          <label for="vsc">VSC (Service Contract)</label>
          <strong id="vscValue">$0</strong>
        </div>
        <input id="vsc" type="range" min="0" max="9000" step="100" value="0">
      </div>

      <div class="field">
        <div class="row">
          <label for="gap">GAP</label>
          <strong id="gapValue">$0</strong>
        </div>
        <input id="gap" type="range" min="0" max="1295" step="5" value="0">
      </div>

      <div class="field">
        <div class="row">
          <label for="club">CLUB PLUS</label>
          <strong id="clubValue">$0</strong>
        </div>
        <div class="subnote">Tire &amp; Wheel, Dent &amp; Ding, Windshield, Keyfob</div>
        <input id="club" type="range" min="0" max="2420" step="5" value="0">
      </div>

      <div class="field">
        <div class="row">
          <label for="maintenance">Maintenance</label>
          <strong id="maintenanceValue">$0</strong>
        </div>
        <input id="maintenance" type="range" min="0" max="2400" step="5" value="0">
      </div>

      <div class="field">
        <div class="row">
          <label for="paint">Paint &amp; Interior Protection</label>
          <strong id="paintValue">$0</strong>
        </div>
        <input id="paint" type="range" min="0" max="1288" step="4" value="0">
      </div>
    </section>

    <section class="comparison">
      <div class="card comparison-card">
        <h2>No Products</h2>
        <div class="metric"><span>Total</span><strong id="baseTotal">$4,000</strong></div>
        <div class="metric"><span>Tax Savings</span><strong id="baseTax">$800</strong></div>
        <div class="metric total"><span>Net</span><strong id="baseNet">$3,200</strong></div>
      </div>

      <div class="card comparison-card highlight">
        <h2>With Products</h2>
        <div class="metric"><span>Total</span><strong id="fullTotal">$4,000</strong></div>
        <div class="metric"><span>Tax Savings</span><strong id="fullTax">$800</strong></div>
        <div class="metric total"><span>Net</span><strong id="fullNet">$3,200</strong></div>
      </div>
    </section>

    <section class="card payoff">
      <p class="eyebrow">Estimated Monthly Impact</p>
      <div class="big-number" id="monthlyImpact">$53.33 / mo</div>
      <p class="muted" id="monthlyTerm">Over 60 months</p>
    </section>

    <footer class="footer">
      Estimated potential tax benefit. Customer should consult a tax professional.
    </footer>
  </div>

  <script src="./app.js"></script>
</body>
</html>
